/[Aa]ssets/
/[Pp]ackages/
/[Pp]roject[Ss]ettings/
/[Vv]ideo[Cc]aptures/

# 3. CHẶN CÁC FILE RÁC & CẤU HÌNH (Nguồn: .gitignore của bạn)
.vs/
.idea/
.vscode/
/*.sln
/*.csproj
/*.dotSettings
/*.user
/*.userprefs
/*.unityproj
/*.booproj
/*.suo
/*.cache
/*.pdb
*.sln.iml
.vsconfig
ExportedObj/
.consulo/
.gradle/
crashlytics-build.properties
.git/

# 4. CHẶN FILE HỆ ĐIỀU HÀNH
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

